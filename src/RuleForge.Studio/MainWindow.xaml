<Window x:Class="RuleForge.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        xmlns:vm="clr-namespace:RuleForge.Studio.ViewModels"
        xmlns:conv="clr-namespace:RuleForge.Studio.Converters"
        Title="RuleForge Studio" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/ruleforge.ico"
        Background="#FFF3F4F6"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>

        <!-- ===== Object Explorer tree templates (auto-applied by data type) ===== -->
        <HierarchicalDataTemplate DataType="{x:Type vm:ConnectionNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF4F46E5" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF1F2937"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type vm:FolderNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF94A3B8" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF334155"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type vm:RuleNodeViewModel}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF2563EB" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#FF1F2937"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReferenceSetNodeViewModel}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF059669" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#FF1F2937"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MessageNodeViewModel}">
            <TextBlock Text="{Binding Name}" FontStyle="Italic" Foreground="#FF94A3B8"/>
        </DataTemplate>

        <!-- ===== Nodify node card ===== -->
        <DataTemplate x:Key="NodeTemplate" DataType="{x:Type vm:NodeViewModel}">
            <Border Width="172" Height="68" CornerRadius="6" Background="White"
                    BorderBrush="#FFE2E8F0" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect Color="#FF94A3B8" BlurRadius="8" ShadowDepth="1" Opacity="0.35"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="6,6,0,0" Background="{Binding AccentBrush}" Padding="8,3">
                        <TextBlock Text="{Binding CategoryLabel}" Foreground="White"
                                   FontSize="10.5" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="9,5,9,5"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap" MaxHeight="34" Foreground="#FF1F2937" FontSize="12.5"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="NodeContainerStyle" TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>

        <DataTemplate x:Key="ConnectionTemplate" DataType="{x:Type vm:ConnectionViewModel}">
            <nodify:LineConnection Source="{Binding Source}" Target="{Binding Target}"
                                   Stroke="{Binding Stroke}" StrokeThickness="2"/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Add Connection…" Click="OnConnectClick"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Help">
                <MenuItem Header="_About RuleForge Studio"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#FFE5E7EB">
            <StatusBarItem Content="{Binding RuleHeader}"/>
            <StatusBarItem HorizontalAlignment="Right" Content="RuleForge Studio v0.9.0 · Phase 1"/>
        </StatusBar>

        <avalonDock:DockingManager x:Name="Dock">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <avalonDock:LayoutAnchorablePane DockWidth="280">
                        <avalonDock:LayoutAnchorable Title="Object Explorer" CanClose="False" CanHide="False">
                            <TreeView x:Name="ExplorerTree" Margin="4" BorderThickness="0"
                                      Background="Transparent"
                                      ItemsSource="{Binding ExplorerRoots}"
                                      SelectedItemChanged="OnTreeSelected">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="Padding" Value="2,1"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutDocumentPaneGroup>
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="Workspace" CanClose="False">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Toolbar (rules only) -->
                                    <Border Grid.Row="0" Background="#FFEFF2F6" BorderBrush="#FFE2E8F0"
                                            BorderThickness="0,0,0,1" Padding="8,5"
                                            Visibility="{Binding ShowReferenceView, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="＋ Add filter" Command="{Binding AddFilterCommand}"
                                                    Padding="10,3" Background="White" BorderBrush="#FFCBD5E1" Cursor="Hand"/>
                                            <TextBlock Text="Select a filter node to edit it below."
                                                       Foreground="#FF94A3B8" VerticalAlignment="Center"
                                                       Margin="12,0,0,0" FontSize="11.5"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Rule designer -->
                                    <Border Grid.Row="1" Background="#FFFBFBFD"
                                            Visibility="{Binding ShowReferenceView, Converter={StaticResource InverseBoolToVis}}">
                                        <nodify:NodifyEditor x:Name="Editor"
                                                             ItemsSource="{Binding Graph.Nodes}"
                                                             Connections="{Binding Graph.Connections}"
                                                             ItemTemplate="{StaticResource NodeTemplate}"
                                                             ItemContainerStyle="{StaticResource NodeContainerStyle}"
                                                             ConnectionTemplate="{StaticResource ConnectionTemplate}"
                                                             GridCellSize="16"
                                                             Background="#FFFBFBFD"/>
                                    </Border>
                                    <!-- Datasource (reference-set) grid -->
                                    <DockPanel Grid.Row="1" Background="White"
                                               Visibility="{Binding ShowReferenceView, Converter={StaticResource BoolToVis}}">
                                        <Border DockPanel.Dock="Top" Background="#FFF1F5F9" Padding="12,8"
                                                BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1">
                                            <TextBlock Text="{Binding ReferenceTitle}" FontWeight="SemiBold"
                                                       Foreground="#FF334155"/>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding ReferenceData}" IsReadOnly="True"
                                                  AutoGenerateColumns="True" HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal" BorderThickness="0"
                                                  RowBackground="White" AlternatingRowBackground="#FFF8FAFC"
                                                  Background="White" FontSize="12"
                                                  HorizontalGridLinesBrush="#FFEDF0F4"/>
                                    </DockPanel>

                                    <!-- Schema-aware filter inspector -->
                                    <Border Grid.Row="2" Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                            BorderThickness="0,1,0,0" Padding="10,8"
                                            Visibility="{Binding Inspector, Converter={StaticResource NullToVis}}">
                                        <WrapPanel DataContext="{Binding Inspector}">
                                            <TextBlock Text="Filter · request field:" VerticalAlignment="Center"
                                                       Foreground="#FF334155" FontWeight="SemiBold"/>
                                            <ComboBox ItemsSource="{Binding Fields}" SelectedItem="{Binding SelectedField}"
                                                      DisplayMemberPath="Display" Width="235" Margin="8,0,0,0"/>
                                            <TextBlock Text="operator" VerticalAlignment="Center"
                                                       Foreground="#FF334155" Margin="14,0,0,0"/>
                                            <ComboBox ItemsSource="{Binding Operators}" SelectedItem="{Binding Operator}"
                                                      Width="130" Margin="8,0,0,0"/>
                                            <TextBlock Text="value" VerticalAlignment="Center"
                                                       Foreground="#FF334155" Margin="14,0,0,0"/>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding ValueEnabled}" Width="170" Margin="8,0,0,0"
                                                     VerticalContentAlignment="Center" BorderBrush="#FFCBD5E1"/>
                                            <Button Content="Apply &amp; run" Margin="14,0,0,0" Padding="12,4"
                                                    Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.ApplyFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </WrapPanel>
                                    </Border>
                                </Grid>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutDocumentPaneGroup>

                    <avalonDock:LayoutAnchorablePane DockWidth="360">
                        <avalonDock:LayoutAnchorable Title="Test Harness" CanClose="False" CanHide="False">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Request (JSON)" FontWeight="SemiBold"
                                           Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" Text="{Binding RequestJson, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         BorderBrush="#FFCBD5E1" Background="White"/>
                                <Button Grid.Row="2" Content="▶  Run in-process" Command="{Binding RunCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,8" Padding="12,5"
                                        Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock Grid.Row="3" Text="Result &amp; trace" FontWeight="SemiBold"
                                           Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="4" Text="{Binding ResultText, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="12" Background="#FFF8FAFC"
                                         BorderBrush="#FFCBD5E1" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </DockPanel>
</Window>

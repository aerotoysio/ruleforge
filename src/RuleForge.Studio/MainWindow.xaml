<Window x:Class="RuleForge.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        xmlns:vm="clr-namespace:RuleForge.Studio.ViewModels"
        Title="RuleForge Studio" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/ruleforge.ico"
        Background="#FFF3F4F6"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <!-- A single node card. Fixed size so connection anchors line up. -->
        <DataTemplate x:Key="NodeTemplate" DataType="{x:Type vm:NodeViewModel}">
            <Border Width="172" Height="68" CornerRadius="6" Background="White"
                    BorderBrush="#FFE2E8F0" BorderThickness="1" SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect Color="#FF94A3B8" BlurRadius="8" ShadowDepth="1" Opacity="0.35"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="6,6,0,0" Background="{Binding AccentBrush}" Padding="8,3">
                        <TextBlock Text="{Binding CategoryLabel}" Foreground="White"
                                   FontSize="10.5" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="9,5,9,5"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap" MaxHeight="34" Foreground="#FF1F2937" FontSize="12.5"/>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="NodeContainerStyle" TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}"/>
        </Style>

        <DataTemplate x:Key="ConnectionTemplate" DataType="{x:Type vm:ConnectionViewModel}">
            <nodify:LineConnection Source="{Binding Source}" Target="{Binding Target}"
                                   Stroke="{Binding Stroke}" StrokeThickness="2"/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect to DocumentForge…" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Help">
                <MenuItem Header="_About RuleForge Studio"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="#FFE5E7EB">
            <StatusBarItem Content="{Binding RuleHeader}"/>
            <StatusBarItem HorizontalAlignment="Right" Content="RuleForge Studio v0.9.0 · Phase 0"/>
        </StatusBar>

        <avalonDock:DockingManager x:Name="Dock">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <avalonDock:LayoutAnchorablePane DockWidth="260">
                        <avalonDock:LayoutAnchorable Title="Object Explorer" CanClose="False" CanHide="False">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Rules (fixtures)" Margin="10,8,10,4"
                                           FontWeight="SemiBold" Foreground="#FF334155"/>
                                <ListBox Margin="4" BorderThickness="0" Background="Transparent"
                                         ItemsSource="{Binding Rules}"
                                         SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                                         DisplayMemberPath="Display"/>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutDocumentPaneGroup>
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="Rule Designer" CanClose="False">
                                <Border Background="#FFFBFBFD">
                                    <nodify:NodifyEditor x:Name="Editor"
                                                         ItemsSource="{Binding Graph.Nodes}"
                                                         Connections="{Binding Graph.Connections}"
                                                         ItemTemplate="{StaticResource NodeTemplate}"
                                                         ItemContainerStyle="{StaticResource NodeContainerStyle}"
                                                         ConnectionTemplate="{StaticResource ConnectionTemplate}"
                                                         GridCellSize="16"
                                                         Background="#FFFBFBFD"/>
                                </Border>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutDocumentPaneGroup>

                    <avalonDock:LayoutAnchorablePane DockWidth="360">
                        <avalonDock:LayoutAnchorable Title="Test Harness" CanClose="False" CanHide="False">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Request (JSON)" FontWeight="SemiBold"
                                           Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" Text="{Binding RequestJson, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         BorderBrush="#FFCBD5E1" Background="White"/>
                                <Button Grid.Row="2" Content="▶  Run in-process" Command="{Binding RunCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,8" Padding="12,5"
                                        Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock Grid.Row="3" Text="Result &amp; trace" FontWeight="SemiBold"
                                           Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="4" Text="{Binding ResultText, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="12" Background="#FFF8FAFC"
                                         BorderBrush="#FFCBD5E1" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </DockPanel>
</Window>

<Window x:Class="RuleForge.Studio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:adtheme="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
        xmlns:vm="clr-namespace:RuleForge.Studio.ViewModels"
        xmlns:conv="clr-namespace:RuleForge.Studio.Converters"
        Title="RuleForge Studio" Height="800" Width="1320"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/ruleforge.ico"
        Background="{StaticResource App.Background}"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:EnumToVisibilityConverter x:Key="EnumVis"/>

        <HierarchicalDataTemplate DataType="{x:Type vm:ConnectionNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF4F46E5" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF1F2937"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        <HierarchicalDataTemplate DataType="{x:Type vm:FolderNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF94A3B8" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF334155"/>
            </StackPanel>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type vm:RuleNodeViewModel}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF2563EB" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#FF1F2937"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReferenceSetNodeViewModel}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Foreground="#FF059669" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="#FF1F2937"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MessageNodeViewModel}">
            <TextBlock Text="{Binding Name}" FontStyle="Italic" Foreground="#FF94A3B8"/>
        </DataTemplate>

        <DataTemplate x:Key="NodeTemplate" DataType="{x:Type vm:NodeViewModel}">
            <nodify:Node Header="{Binding CategoryLabel}" HeaderBrush="{Binding AccentBrush}"
                         Input="{Binding Inputs}" Output="{Binding Outputs}"
                         Background="White" ContentBrush="White"
                         Foreground="#3A4358" BorderBrush="#E4E7F0" BorderThickness="1"
                         ContentPadding="14,10,14,12"
                         ToolTip="Double-click to edit · drag a connector to link">
                <nodify:Node.HeaderTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="11" Padding="4,3"
                                   Foreground="{Binding DataContext.HeaderTextBrush,
                                                RelativeSource={RelativeSource AncestorType=nodify:Node}}"/>
                    </DataTemplate>
                </nodify:Node.HeaderTemplate>
                <nodify:Node.InputConnectorTemplate>
                    <DataTemplate>
                        <nodify:NodeInput Header="{Binding Title}" Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                          IsConnected="{Binding IsConnected}"
                                          Background="Transparent" BorderBrush="Transparent"
                                          Foreground="#8B94A9" FontSize="10.5"/>
                    </DataTemplate>
                </nodify:Node.InputConnectorTemplate>
                <nodify:Node.OutputConnectorTemplate>
                    <DataTemplate>
                        <nodify:NodeOutput Header="{Binding Title}" Anchor="{Binding Anchor, Mode=OneWayToSource}"
                                           IsConnected="{Binding IsConnected}"
                                           Background="Transparent" BorderBrush="Transparent"
                                           Foreground="#8B94A9" FontSize="10.5"/>
                    </DataTemplate>
                </nodify:Node.OutputConnectorTemplate>
                <StackPanel MinWidth="150" MaxWidth="220" Margin="2,4">
                    <TextBlock Text="{Binding Title}" Foreground="#2E3648" FontSize="13.5"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Description}" Foreground="#8B94A9" FontSize="11.5"
                               TextWrapping="Wrap" MaxHeight="52" Margin="0,4,0,0"
                               Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </nodify:Node>
        </DataTemplate>

        <Style x:Key="NodeContainerStyle" TargetType="nodify:ItemContainer">
            <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>

        <DataTemplate x:Key="ConnectionTemplate" DataType="{x:Type vm:ConnectionViewModel}">
            <nodify:LineConnection Source="{Binding Source.Anchor}" Target="{Binding Target.Anchor}"
                                   Stroke="{Binding Stroke}" StrokeThickness="2"/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Add Connection…" Click="OnConnectClick"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExit"/>
            </MenuItem>
            <MenuItem Header="_Data">
                <MenuItem Header="New _key-value list…" Click="OnNewKeyValue"/>
                <MenuItem Header="New _lookup table…" Click="OnNewLookup"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Rule Tester" Command="{Binding OpenTesterCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About RuleForge Studio"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource App.SurfaceAlt}"
                   Foreground="{StaticResource App.Text}">
            <StatusBarItem Content="{Binding StatusText}"/>
            <Separator/>
            <StatusBarItem Content="{Binding RuleHeader}"/>
            <StatusBarItem HorizontalAlignment="Right" Content="RuleForge Studio v0.9.0 · Phase 2"/>
        </StatusBar>

        <avalonDock:DockingManager x:Name="Dock">
            <avalonDock:DockingManager.Theme>
                <adtheme:Vs2013LightTheme/>
            </avalonDock:DockingManager.Theme>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">

                    <avalonDock:LayoutAnchorablePane DockWidth="270">
                        <avalonDock:LayoutAnchorable Title="Object Explorer" CanClose="False" CanHide="False">
                            <TreeView x:Name="ExplorerTree" Margin="4" BorderThickness="0" Background="Transparent"
                                      ItemsSource="{Binding ExplorerRoots}" SelectedItemChanged="OnTreeSelected">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                        <Setter Property="Padding" Value="2,1"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutDocumentPaneGroup>
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="Workspace" CanClose="False">
                                <Grid>
                                    <!-- ============ DESIGNER ============ -->
                                    <Grid Visibility="{Binding CenterMode, Converter={StaticResource EnumVis}, ConverterParameter=Designer}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="#FFEFF2F6" BorderBrush="#FFE2E8F0"
                                                BorderThickness="0,0,0,1" Padding="8,5">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="＋ Add filter" Command="{Binding AddFilterCommand}"
                                                        Style="{StaticResource SubtleButton}"/>
                                                <TextBlock Text="Double-click a node to edit · drag a connector to link · drag from the Toolbox to add"
                                                           Foreground="#FF94A3B8" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11.5"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Row="1" Background="#FFFBFBFD">
                                            <nodify:NodifyEditor x:Name="Editor"
                                                                 ItemsSource="{Binding Graph.Nodes}"
                                                                 Connections="{Binding Graph.Connections}"
                                                                 PendingConnection="{Binding Graph.PendingConnection}"
                                                                 ItemTemplate="{StaticResource NodeTemplate}"
                                                                 ItemContainerStyle="{StaticResource NodeContainerStyle}"
                                                                 ConnectionTemplate="{StaticResource ConnectionTemplate}"
                                                                 GridCellSize="16" Background="#FFFBFBFD"
                                                                 AllowDrop="True" Drop="OnEditorDrop" DragOver="OnEditorDragOver"
                                                                 PreviewMouseLeftButtonDown="OnEditorPreviewMouseDown">
                                                <nodify:NodifyEditor.PendingConnectionTemplate>
                                                    <DataTemplate DataType="{x:Type vm:PendingConnectionViewModel}">
                                                        <nodify:PendingConnection Source="{Binding Source}"
                                                                                  StartedCommand="{Binding StartCommand}"
                                                                                  CompletedCommand="{Binding FinishCommand}"
                                                                                  AllowOnlyConnectors="True"/>
                                                    </DataTemplate>
                                                </nodify:NodifyEditor.PendingConnectionTemplate>
                                            </nodify:NodifyEditor>
                                        </Border>
                                    </Grid>

                                    <!-- ============ DATASOURCE (reference data) ============ -->
                                    <DockPanel Background="White"
                                               Visibility="{Binding CenterMode, Converter={StaticResource EnumVis}, ConverterParameter=Datasource}">
                                        <Border DockPanel.Dock="Top" Background="#FFF1F5F9" Padding="10,6"
                                                BorderBrush="#FFE2E8F0" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Name:" VerticalAlignment="Center" Foreground="#FF334155" Margin="0,0,6,0"/>
                                                <TextBox Text="{Binding ReferenceEditName, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="220" VerticalContentAlignment="Center" BorderBrush="#FFCBD5E1"/>
                                                <Button Content="Add column" Click="OnAddReferenceColumn" Margin="12,0,0,0" Style="{StaticResource SubtleButton}"/>
                                                <Button Content="Import CSV…" Click="OnImportReferenceCsv" Margin="6,0,0,0" Style="{StaticResource SubtleButton}"/>
                                                <Button Content="Save" Command="{Binding SaveReferenceSetCommand}" Margin="12,0,0,0"
                                                        Style="{StaticResource AccentButton}"/>
                                                <Button Content="Delete" Command="{Binding DeleteReferenceSetCommand}" Margin="6,0,0,0" Style="{StaticResource SubtleButton}"/>
                                            </StackPanel>
                                        </Border>
                                        <DataGrid ItemsSource="{Binding ReferenceData}" AutoGenerateColumns="True"
                                                  CanUserAddRows="True" CanUserDeleteRows="True" HeadersVisibility="All"
                                                  GridLinesVisibility="All" BorderThickness="0"
                                                  RowBackground="White" AlternatingRowBackground="#FFF8FAFC"
                                                  Background="White" FontSize="12" HorizontalGridLinesBrush="#FFEDF0F4"
                                                  VerticalGridLinesBrush="#FFEDF0F4"/>
                                    </DockPanel>

                                    <!-- ============ RULE TESTER ============ -->
                                    <Grid Margin="16" Background="#FFFBFBFD"
                                          Visibility="{Binding CenterMode, Converter={StaticResource EnumVis}, ConverterParameter=Tester}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="2*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="3*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Rule Tester — send JSON, see the output" FontWeight="SemiBold"
                                                       FontSize="14" Foreground="#FF1F2937" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Rule:" VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="#FF334155" Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{Binding AllRules}" SelectedItem="{Binding SelectedTestRule}"
                                                      DisplayMemberPath="Name" Width="360"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="2" Text="{Binding TesterRequestJson, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12.5"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                 BorderBrush="#FFCBD5E1" Background="White" Margin="0,0,0,8"/>
                                        <Button Grid.Row="3" Content="▶  Send" Command="{Binding RunTesterCommand}"
                                                HorizontalAlignment="Left" Margin="0,0,0,10"
                                                Style="{StaticResource AccentButton}"/>
                                        <TextBlock Grid.Row="4" Text="Output" FontWeight="SemiBold" Foreground="#FF334155" Margin="0,0,0,4"/>
                                        <TextBox Grid.Row="5" Text="{Binding TesterResultText, Mode=OneWay}" IsReadOnly="True"
                                                 FontFamily="Consolas" FontSize="12.5" Background="#FFF8FAFC"
                                                 BorderBrush="#FFCBD5E1" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Grid>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutDocumentPaneGroup>

                    <avalonDock:LayoutAnchorablePane DockWidth="150">
                        <avalonDock:LayoutAnchorable Title="Toolbox" CanClose="False" CanHide="False">
                            <ItemsControl ItemsSource="{Binding Toolbox}" Margin="6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,3" Padding="8,6" CornerRadius="5" Background="White"
                                                BorderBrush="#FFE2E8F0" BorderThickness="1" Cursor="Hand"
                                                MouseMove="OnToolboxItemMouseMove" ToolTip="Drag onto the canvas">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="11" Height="11" CornerRadius="2" Background="{Binding Color}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#FF1F2937"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutAnchorablePane DockWidth="360">
                        <avalonDock:LayoutAnchorable Title="Test Harness" CanClose="False" CanHide="False">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Request (JSON)" FontWeight="SemiBold" Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" Text="{Binding RequestJson, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="12"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         BorderBrush="#FFCBD5E1" Background="White"/>
                                <Button Grid.Row="2" Content="▶  Run in-process" Command="{Binding RunCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,8"
                                        Style="{StaticResource AccentButton}"/>
                                <TextBlock Grid.Row="3" Text="Result &amp; trace" FontWeight="SemiBold" Foreground="#FF334155" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="4" Text="{Binding ResultText, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="12" Background="#FFF8FAFC"
                                         BorderBrush="#FFCBD5E1" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </DockPanel>
</Window>

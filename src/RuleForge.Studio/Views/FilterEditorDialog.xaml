<Window x:Class="RuleForge.Studio.Views.FilterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit filter" Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFF3F4F6" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF334155"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18,10,18,16">
        <TextBlock Text="Filter · request field" Margin="0,0,0,3"/>
        <ComboBox ItemsSource="{Binding Fields}" SelectedItem="{Binding SelectedField}" DisplayMemberPath="Display"/>

        <TextBlock Text="Operator"/>
        <ComboBox ItemsSource="{Binding Operators}" SelectedItem="{Binding Operator}"/>

        <TextBlock Text="Value"/>
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding ValueEnabled}"
                 Padding="4,3" BorderBrush="#FFCBD5E1"/>
        <TextBlock Text="For 'in' / 'not in', separate values with commas."
                   FontWeight="Normal" FontSize="11" Foreground="#FF94A3B8" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="OK" IsDefault="True" Click="OnOk" Padding="16,5"
                    Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

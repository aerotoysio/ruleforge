<Window x:Class="RuleForge.Studio.Views.FilterEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RuleForge.Studio.Converters"
        xmlns:vm="clr-namespace:RuleForge.Studio.ViewModels"
        Title="Edit filter" Width="780" Height="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F6F7FB" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3A4358"/>
            <Setter Property="Margin" Value="0,12,0,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B94A9"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#E4E7F0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16,10,16,14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== LEFT: request element (searchable hierarchy, type-filtered) ===== -->
        <Grid Grid.Column="0" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Request element" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
            <TextBox Grid.Row="1" Text="{Binding FieldSearch, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,6" Background="White"
                     ToolTip="Search the request fields"/>
            <Border Grid.Row="2" Background="White" BorderBrush="#E4E7F0" BorderThickness="1" CornerRadius="6">
                <ListBox ItemsSource="{Binding FilteredFields}" SelectedItem="{Binding SelectedField}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="{Binding Indent}"/>
                                <TextBlock Text="{Binding LeafName}" Foreground="#3A4358" FontSize="12.5"/>
                                <TextBlock Text="{Binding TypeName}" Foreground="#8B94A9" FontSize="10.5"
                                           Margin="7,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <TextBlock Grid.Row="3" Text="Only fields this filter can apply to (strings) are listed."
                       Style="{StaticResource Hint}"/>
        </Grid>

        <!-- ===== RIGHT: name, description, conditions ===== -->
        <ScrollViewer Grid.Column="2" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Background="White"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Description (shown on the node)" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Background="White"
                                 ToolTip="Leave blank to auto-describe the filter"/>
                    </StackPanel>
                </Grid>

                <!-- Array semantics -->
                <StackPanel Visibility="{Binding IsArrayPath, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="This element is inside a list — how should the list be judged?"
                               Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding ArrayModes}" SelectedItem="{Binding ArrayMode}"
                              DisplayMemberPath="Display"/>
                </StackPanel>

                <!-- Conditions -->
                <DockPanel Margin="0,14,0,4">
                    <TextBlock Text="Conditions" FontWeight="SemiBold" FontSize="13" Foreground="#3A4358"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="＋ Add condition" HorizontalAlignment="Right"
                            Command="{Binding AddConditionCommand}" Style="{StaticResource SubtleButton}"/>
                    <Border/>
                </DockPanel>

                <ComboBox ItemsSource="{Binding MatchModes}" SelectedItem="{Binding MatchMode}"
                          DisplayMemberPath="Display" Margin="0,0,0,8"
                          Visibility="{Binding HasMultipleConditions, Converter={StaticResource BoolToVis}}"/>

                <ItemsControl ItemsSource="{Binding Conditions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ConditionViewModel}">
                            <Border Background="White" BorderBrush="#E4E7F0" BorderThickness="1"
                                    CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="✕" FontSize="10" Padding="6,2"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Foreground="#8B94A9" ToolTip="Remove this condition"
                                                Command="{Binding DataContext.RemoveConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <ComboBox ItemsSource="{Binding Operators}" SelectedItem="{Binding Operator}"
                                                  Width="150" HorizontalAlignment="Left"/>
                                    </DockPanel>

                                    <!-- single value -->
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,8,0,0"
                                             Visibility="{Binding ShowSingleValue, Converter={StaticResource BoolToVis}}"/>

                                    <!-- multiple values -->
                                    <StackPanel Visibility="{Binding IsListOperator, Converter={StaticResource BoolToVis}}"
                                                Margin="0,8,0,0">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="From reference data…"
                                                    Click="OnPickFromReference" Margin="6,0,0,0"
                                                    Style="{StaticResource SubtleButton}"/>
                                            <Button DockPanel.Dock="Right" Content="Add" Margin="6,0,0,0"
                                                    Command="{Binding AddValueCommand}"
                                                    Style="{StaticResource SubtleButton}"/>
                                            <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}"
                                                     PreviewKeyDown="OnNewValueKeyDown"/>
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Values}" Margin="0,6,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#E4E6FA" BorderBrush="#C9CDF4" BorderThickness="1"
                                                            CornerRadius="10" Padding="9,2,5,2" Margin="2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding}" Foreground="#4550A8" FontSize="12"
                                                                       VerticalAlignment="Center"/>
                                                            <Button Content="✕" FontSize="9" Padding="4,1" Margin="5,0,0,0"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                    Foreground="#8B94A9"
                                                                    Command="{Binding DataContext.RemoveValueCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox Content="Ignore case" IsChecked="{Binding CaseInsensitive}" Foreground="#3A4358"/>
                    <CheckBox Content="Trim whitespace" IsChecked="{Binding Trim}" Margin="16,0,0,0" Foreground="#3A4358"/>
                </StackPanel>

                <TextBlock Text="If the element is missing from the request" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding MissingModes}" SelectedItem="{Binding MissingMode}"
                          DisplayMemberPath="Display"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Buttons ===== -->
        <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource SubtleButton}" Margin="0,0,8,0"/>
            <Button Content="OK" Click="OnOk" Style="{StaticResource AccentButton}" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>

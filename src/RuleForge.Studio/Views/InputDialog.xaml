<Window x:Class="RuleForge.Studio.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RuleForge Studio" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFF3F4F6" TextOptions.TextFormattingMode="Display">
    <StackPanel Margin="18,14,18,16">
        <TextBlock x:Name="PromptText" Foreground="#FF334155" FontSize="12.5" Margin="0,0,0,6"/>
        <TextBox x:Name="ValueBox" Padding="4,3" BorderBrush="#FFCBD5E1"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="OK" IsDefault="True" Click="OnOk" Padding="16,5"
                    Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

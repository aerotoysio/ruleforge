<Window x:Class="RuleForge.Studio.Views.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Connection" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFF3F4F6" TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF334155"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18,12,18,16">
        <TextBlock Text="Connection name"/>
        <TextBox x:Name="NameBox"/>

        <TextBlock Text="Type"/>
        <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="LocalRadio" Content="Local workspace folder" GroupName="kind"
                         IsChecked="True" Checked="OnKindChanged"/>
            <RadioButton x:Name="DfRadio" Content="DocumentForge" GroupName="kind"
                         Checked="OnKindChanged" Margin="18,0,0,0"/>
        </StackPanel>

        <StackPanel x:Name="LocalPanel">
            <TextBlock Text="Workspace folder (contains rules\ and refs\)"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse…" Click="OnBrowse" Padding="10,3" Margin="6,0,0,0"/>
                <TextBox x:Name="FolderBox"/>
            </DockPanel>
        </StackPanel>

        <StackPanel x:Name="DfPanel" Visibility="Collapsed">
            <TextBlock Text="DocumentForge URL"/>
            <TextBox x:Name="UrlBox" Text="https://documentforge.onrender.com"/>
            <TextBlock Text="API key (stored DPAPI-encrypted)"/>
            <PasswordBox x:Name="KeyBox"/>
            <TextBlock Text="Environment"/>
            <TextBox x:Name="EnvBox" Text="staging"/>
            <TextBlock Text="Collection prefix (optional)"/>
            <TextBox x:Name="PrefixBox"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="#FFDC2626" Visibility="Collapsed" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="Add" Click="OnOk" Padding="14,5"
                    Background="#FF2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

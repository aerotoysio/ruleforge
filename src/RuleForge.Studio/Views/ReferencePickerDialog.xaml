<Window x:Class="RuleForge.Studio.Views.ReferencePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick values from reference data" Width="440" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F6F7FB" TextOptions.TextFormattingMode="Display">
    <Grid Margin="16,12,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Datasource" FontWeight="SemiBold" Foreground="#3A4358" Margin="0,0,0,3"/>
            <ComboBox x:Name="SetCombo" DisplayMemberPath="Name" SelectionChanged="OnSetChanged" Padding="4,3"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Show column" FontWeight="SemiBold" Foreground="#3A4358" Margin="0,0,0,3"/>
                <ComboBox x:Name="DisplayCombo" SelectionChanged="OnColumnsChanged" Padding="4,3"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Use value from" FontWeight="SemiBold" Foreground="#3A4358" Margin="0,0,0,3"/>
                <ComboBox x:Name="ValueCombo" SelectionChanged="OnColumnsChanged" Padding="4,3"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#E4E7F0" BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="RowsList" Margin="8,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked}" Margin="0,3" Foreground="#3A4358">
                                <TextBlock>
                                    <Run Text="{Binding Display, Mode=OneWay}"/>
                                    <Run Text="{Binding ValueHint, Mode=OneWay}" Foreground="#8B94A9"/>
                                </TextBlock>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True" Style="{StaticResource SubtleButton}" Margin="0,0,8,0"/>
            <Button Content="Add selected" Click="OnOk" Style="{StaticResource AccentButton}"/>
        </StackPanel>
    </Grid>
</Window>
